#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

source $HOME/OpenFOAM/OpenFOAM-dev/etc/bashrc
export EDITOR="vim"
export VISUAL= "vim"
export TERMINAL=ghostty
eval "$(starship init bash)"   # or zsh




source ~/bash_functions.sh




#aliases
alias ebash="nano ~/.bashrc"
alias eghostty="nano ~/.config/ghostty/config"
alias enoctalia="nano ~/.config/noctalia/config.yaml"
alias foobar='venit2007@192.168.29.182'


eval "$(starship init bash)"
export PATH="$HOME/.local/share/gem/ruby/3.4.0/bin:$PATH" 
